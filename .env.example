# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production

# Database (MySQL)
# Desenvolvimento local: mysql+pymysql://root:password@localhost/cuidador_db
# PythonAnywhere: mysql+pymysql://usuario:senha@usuario.mysql.pythonanywhere-services.com/usuario$cuidador
DATABASE_URL=mysql+pymysql://root:password@localhost/cuidador_db

# JWT
JWT_SECRET_KEY=jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=2592000

# CORS
CORS_ORIGINS=*
